# Conta Gmail usada como remetente do formulário de contato (src/pages/api/contact.ts).
# Gere uma "senha de app" em: https://myaccount.google.com/apppasswords
# (precisa de verificação em 2 etapas ativada na conta).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Opcional: e-mail que recebe as mensagens do formulário (padrão: adv.guilhermecallegari@gmail.com)
CONTACT_TO_EMAIL=

# Cloudflare Turnstile (captcha invisível anti-bot) — https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY é pública (vai no HTML). TURNSTILE_SECRET_KEY é privada, nunca a exponha no frontend.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
