  { src: '/fotos/recepcao-logo.png', alt: 'Recepção Callegari & Dias', span: 'tall' },
  { src: '/fotos/sala-reuniao.png', alt: 'Sala de reunião', span: 'tall' },
  { src: '/fotos/recepcao-espera.png', alt: 'Sala de espera', span: 'tall' },
