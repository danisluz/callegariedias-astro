  { src: '/fotos/quadro-arvore.png', alt: 'Ambiente de trabalho', span: 'tall' },
  { src: '/fotos/fachada.png', alt: 'Fachada Bento Gonçalves Corporate, 708', span: 'wide', caption: 'Bento Gonçalves Corporate · nº 708 — Viamão/RS' }
