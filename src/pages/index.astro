---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Callegari & Dias Advocacia</title>
    <meta
      name="description"
      content="Callegari & Dias Advocacia: advocacia especializada e humanizada em Viamão/RS."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f4f0e9;
        --bg-strong: #0a2a31;
        --teal: #0e3640;
        --teal-deep: #103a43;
        --teal-soft: #12404b;
        --accent: #c75b43;
        --accent-soft: #e0a99b;
        --text: #1c2326;
        --muted: #5c666a;
        --line: #d9d1c2;
        --shadow: 0 30px 70px -35px rgba(10, 42, 49, 0.45);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Manrope', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      ::selection { background: var(--accent); color: #fff; }
      img { max-width: 100%; display: block; }
      a { color: inherit; }
      section, header { scroll-margin-top: 96px; }

      .page {
        position: relative;
        overflow: clip;
      }

      .container {
        width: min(1240px, calc(100% - 40px));
        margin: 0 auto;
      }

      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.85s cubic-bezier(0.16, 0.84, 0.32, 1), transform 0.85s cubic-bezier(0.16, 0.84, 0.32, 1);
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 22px clamp(20px, 5vw, 72px);
        transition: background 0.35s ease, padding 0.35s ease, box-shadow 0.35s ease;
      }

      .nav.is-scrolled {
        padding: 14px clamp(20px, 5vw, 72px);
        background: rgba(10, 42, 49, 0.92);
        backdrop-filter: blur(10px);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.07);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: clamp(18px, 2.4vw, 40px);
      }

      .nav-link {
        text-decoration: none;
        font-size: 13.5px;
        font-weight: 600;
        letter-spacing: 0.3px;
        color: rgba(255, 255, 255, 0.82);
      }

      .nav-link:hover { color: #fff; }
      .button-primary {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 11px;
        background: var(--accent);
        color: #fff;
        font-weight: 700;
        font-size: 14.5px;
        letter-spacing: 0.3px;
        padding: 18px 32px;
        border-radius: 2px;
        border: 0;
        transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
      }

      .button-primary:hover {
        background: #b04d37;
        transform: translateY(-2px);
      }

      .button-ghost {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #fff;
        font-weight: 600;
        font-size: 14.5px;
        letter-spacing: 0.3px;
        padding: 18px 8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.35);
        transition: border-color 0.3s ease;
      }

      .button-ghost:hover { border-color: var(--accent); }

      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--bg-strong);
        padding-top: 110px;
        padding-bottom: 130px;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transform: scale(1.08);
        animation: kenburns 18s ease-out forwards;
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          linear-gradient(105deg, rgba(8, 40, 47, 0.94) 0%, rgba(8, 40, 47, 0.78) 45%, rgba(8, 40, 47, 0.42) 100%),
          linear-gradient(0deg, rgba(8, 40, 47, 0.85) 0%, rgba(8, 40, 47, 0) 38%);
      }

      .hero-slides {
        position: relative;
        z-index: 2;
        flex: 1 1 auto;
        min-height: 0;
      }

      .eyebrow {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 30px;
      }

      .eyebrow::before {
        content: '';
        width: 42px;
        height: 1px;
        background: var(--accent);
        flex: 0 0 auto;
      }

      .eyebrow span {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 4px;
        color: var(--accent-soft);
        text-transform: uppercase;
      }

      .hero-title {
        margin: 0;
        font-family: 'Spectral', serif;
        font-weight: 400;
        font-size: clamp(36px, min(6.2vw, 7.2vh), 82px);
        line-height: 1.04;
        color: #fff;
        letter-spacing: -1px;
      }

      .hero-line {
        display: block;
      }

      .hero-accent {
        font-style: italic;
        font-weight: 300;
        color: #e9e2d6;
      }

      .hero-text {
        margin-top: 28px;
        max-width: 500px;
        font-size: clamp(15px, 1.5vw, 18px);
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.78);
      }

      .hero-actions {
        margin-top: 42px;
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: center;
      }

      .hero-controls {
        position: relative;
        z-index: 6;
        flex: 0 0 auto;
      }

      .hero-controls-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .dots {
        display: flex;
        gap: 9px;
        align-items: center;
      }

      .dot {
        height: 4px;
        width: 10px;
        border: none;
        padding: 0;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.4);
        border-radius: 2px;
        transition: all 0.4s ease;
      }

      .dot.is-active {
        width: 34px;
        background: var(--accent);
      }

      .arrow {
        width: 48px;
        height: 48px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        background: transparent;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
      }

      .arrow:hover {
        background: var(--accent);
        border-color: var(--accent);
      }

      .slide {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 1.1s ease;
      }

      .slide.is-active {
        opacity: 1;
        pointer-events: auto;
      }

      .slide-inner {
        max-width: 640px;
      }

      .feature-strip {
        position: relative;
        z-index: 5;
        margin-top: -90px;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        background: #fff;
        box-shadow: var(--shadow);
      }

      .feature-card {
        padding: clamp(32px, 3.5vw, 52px);
        border-top: 3px solid var(--accent);
        border-right: 1px solid #ece6db;
        background: #fff;
      }

      .feature-card:last-child { border-right: 0; }

      .feature-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        margin-bottom: 24px;
      }

      .section-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: clamp(40px, 6vw, 90px);
        align-items: center;
      }

      .heading {
        margin: 0;
        font-family: 'Spectral', serif;
        font-weight: 400;
        font-size: clamp(34px, 4.4vw, 56px);
        line-height: 1.08;
        color: var(--teal-deep);
        letter-spacing: -0.5px;
      }

      .heading-compact {
        font-size: clamp(32px, 4.2vw, 52px);
        line-height: 1.1;
      }

      .section-copy {
        font-size: 16.5px;
        line-height: 1.85;
        color: #4a5458;
      }

      .quote-card {
        margin-top: 30px;
        padding: 26px 30px;
        background: #fff;
        border-left: 3px solid var(--accent);
        box-shadow: 0 20px 50px -30px rgba(10, 42, 49, 0.4);
      }

      .areas {
        background: var(--teal);
        position: relative;
        overflow: hidden;
      }

      .areas::before {
        content: '';
        position: absolute;
        inset: 0 0 auto auto;
        width: 50%;
        height: 100%;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
      }

      .areas-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: clamp(40px, 5vw, 70px);
      }

      .areas-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1px;
        background: rgba(255, 255, 255, 0.09);
      }

      .area-card {
        background: var(--teal);
        padding: clamp(28px, 2.6vw, 40px);
        transition: background 0.35s ease, transform 0.35s ease;
      }

      .area-card:hover { background: var(--teal-soft); transform: translateY(-2px); }
      .area-card strong, .area-card h3 {
        font-family: 'Spectral', serif;
        font-weight: 500;
      }

      .cta-band {
        background: linear-gradient(180deg, var(--teal) 0%, var(--teal) 50%, var(--bg) 50%, var(--bg) 100%);
      }

      .cta-panel {
        background: #fff;
        box-shadow: 0 30px 70px -35px rgba(10, 42, 49, 0.45);
        padding: clamp(34px, 4vw, 56px);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
      }

      .cta-title {
        margin: 0;
        font-family: 'Spectral', serif;
        font-weight: 500;
        font-size: clamp(24px, 2.8vw, 34px);
        color: var(--teal-deep);
        line-height: 1.15;
      }

      .office-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 220px;
        grid-auto-flow: dense;
        gap: 6px;
      }

      .office-card {
        margin: 0;
        overflow: hidden;
        position: relative;
        background: var(--teal);
      }

      .office-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.7s cubic-bezier(0.16, 0.84, 0.32, 1);
      }

      .office-card:hover img { transform: scale(1.06); }

      .office-card.is-tall { grid-row: span 2; }
      .office-card.is-wide { grid-column: span 2; }

      .contact-layout {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: clamp(48px, 6vw, 90px);
      }

      .contact-form {
        background: var(--bg);
        padding: clamp(28px, 3.5vw, 44px);
        border-top: 3px solid var(--accent);
      }

      label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 8px;
      }

      input, textarea {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid var(--line);
        background: #fff;
        font-family: inherit;
        font-size: 15px;
        color: var(--text);
        outline: none;
        border-radius: 2px;
        transition: border-color 0.2s ease;
      }

      input:focus, textarea:focus { border-color: var(--accent); }
      textarea { resize: vertical; }

      .map-link {
        text-decoration: none;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        background: var(--teal);
        padding: clamp(28px, 3.5vw, 44px) clamp(28px, 4vw, 52px);
        transition: background 0.3s ease;
      }

      .map-link:hover { background: var(--teal-deep); }

      footer {
        background: var(--bg-strong);
        color: #fff;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 48px;
        align-items: start;
      }

      .footer-title {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--accent-soft);
        margin-bottom: 20px;
      }

      .socials {
        display: flex;
        gap: 13px;
      }

      .social {
        width: 44px;
        height: 44px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        transition: all 0.3s ease;
      }

      .social:hover {
        background: var(--accent);
        border-color: var(--accent);
      }

      .social-on-light {
        border-color: var(--line);
        color: var(--teal-deep);
      }

      .social-on-light:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
      }

      .footer-bottom {
        margin-top: clamp(40px, 5vw, 64px);
        padding-top: 28px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: space-between;
        align-items: center;
      }

      .muted {
        color: rgba(255, 255, 255, 0.6);
      }

      .nav-toggle {
        display: none;
        width: 48px;
        height: 48px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: transparent;
        color: #fff;
        border-radius: 2px;
      }

      .mobile-panel {
        display: none;
      }

      @keyframes kenburns {
        from { transform: scale(1.08); }
        to { transform: scale(1.18); }
      }

      @media (max-width: 1100px) {
        .nav-links {
          gap: 16px;
        }
      }

      @media (max-width: 880px) {
        .nav {
          gap: 12px;
          flex-wrap: wrap;
        }

        .nav-links {
          display: none;
        }

        .nav-toggle {
          display: inline-flex;
          align-items: center;
          justify-content: center;
        }

        .mobile-panel:not([hidden]) {
          display: grid;
          width: 100%;
          gap: 12px;
          padding: 14px;
          border: 1px solid rgba(255, 255, 255, 0.12);
          background: rgba(8, 40, 47, 0.96);
          border-radius: 8px;
          margin-top: 8px;
        }

        .mobile-panel a {
          text-decoration: none;
          color: rgba(255, 255, 255, 0.85);
          font-size: 14px;
          font-weight: 600;
        }
      }

      @media (max-width: 768px) {
        .feature-strip { margin-top: -42px; }
        .hero { padding-top: 100px; padding-bottom: 70px; }
        .hero-controls-inner, .cta-panel { flex-direction: column; align-items: flex-start; }
        .button-primary { width: 100%; }
        .hero-title {
          font-size: clamp(34px, 8vw, 56px);
        }
        .slide-inner {
          max-width: 100% !important;
        }
        .office-gallery {
          grid-template-columns: 1fr;
          grid-auto-rows: 220px;
        }
        .office-card.is-tall,
        .office-card.is-wide {
          grid-row: span 1;
          grid-column: span 1;
        }
      }

      @media (max-width: 768px) and (max-height: 700px) {
        .hero { padding-top: 80px; padding-bottom: 56px; }
        .eyebrow { margin-bottom: 16px; }
        .hero-text { margin-top: 14px; }
        .hero-actions { margin-top: 20px; }
      }

      @media (max-height: 480px) {
        .hero { padding-top: 54px; padding-bottom: 50px; }
        .nav { padding: 8px clamp(16px, 4vw, 40px); }
        .brand img { height: 18px !important; }
        .eyebrow { margin-bottom: 6px; }
        .hero-title {
          font-size: clamp(16px, 5vh, 24px);
          line-height: 1.15;
        }
        .hero-text {
          display: none;
        }
        .hero-actions {
          margin-top: 10px;
          gap: 10px;
        }
        .hero-actions .button-primary {
          padding: 8px 16px;
          font-size: 12px;
        }
        .hero-actions .button-ghost {
          padding: 8px 6px;
          font-size: 12px;
        }
        .arrow {
          width: 36px;
          height: 36px;
        }
      }

      @media (max-height: 700px) and (min-width: 769px) {
        .hero { padding-top: 96px; padding-bottom: 110px; }
        .eyebrow { margin-bottom: 16px; }
        .hero-text { margin-top: 14px; }
        .hero-actions { margin-top: 20px; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header id="topo" class="hero">
        <img class="hero-bg" src="/fotos/fachada.png" alt="" aria-hidden="true" />
        <div class="hero-overlay"></div>
        <nav class="nav" aria-label="Principal">
          <a href="#topo" class="brand" aria-label="Callegari & Dias Advocacia">
            <img src="/logo.svg" alt="Callegari & Dias Advogados" style="height: 26px; width: auto;" />
          </a>
          <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 7h16"></path>
              <path d="M4 12h16"></path>
              <path d="M4 17h16"></path>
            </svg>
          </button>
          <div class="nav-links">
            <a href="#sobre" class="nav-link">Sobre</a>
            <a href="#areas" class="nav-link">Áreas de Atuação</a>
            <a href="#escritorio" class="nav-link">Nosso Espaço</a>
            <a href="#contato" class="nav-link">Contato</a>
            <a href="#contato" class="button-primary" style="padding: 12px 22px; font-size: 13px;">Fale Conosco</a>
          </div>
          <div id="mobile-nav" class="mobile-panel" hidden>
            <a href="#sobre">Sobre</a>
